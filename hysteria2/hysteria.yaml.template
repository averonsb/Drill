listen: :443

tls:
  cert: /caddy_data/caddy/certificates/acme-v02.api.letsencrypt.org-directory/${DOMAIN}/${DOMAIN}.crt
  key: /caddy_data/caddy/certificates/acme-v02.api.letsencrypt.org-directory/${DOMAIN}/${DOMAIN}.key

auth:
  type: password
  password: "${HYSTERIA_PASSWORD}"

masquerade:
  type: proxy
  proxy:
    url: https://www.bing.com
    rewriteHost: true
